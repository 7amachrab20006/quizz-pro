rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }

    // Users collection
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn();
      allow write: if isOwner(userId) && isValidId(userId);
    }

    // Scores collection
    match /scores/{scoreId} {
      allow get: if isSignedIn() && isValidId(scoreId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(scoreId) && incoming().userId == request.auth.uid;
      allow update, delete: if false; // Scores are immutable
    }
  }
}
