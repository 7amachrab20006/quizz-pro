# GEMINI_API_KEY: Required for AI-powered features (Generated Quiz & Decision Advisor).
# Obtain from https://aistudio.google.com/
GEMINI_API_KEY="AI_STUDIO_API_KEY"

# Email Configuration: Required for real-time admin notifications on user events (Registration/Login).
# Use a service like Gmail App Passwords, SendGrid, or Mailtrap.
EMAIL_HOST="smtp.example.com"
EMAIL_PORT="587"
EMAIL_USER="system@example.com"
EMAIL_PASS="secure_password"

# The recipient of system notifications.
ADMIN_EMAIL="mohamedbenothmane2006@gmail.com"

# Database URL (SQLite for dev, can be switched to Postgres)
DATABASE_URL="file:./dev.db"

# JWT Secret for Auth
JWT_SECRET="super_secret_quiz_master_token"

# APP_URL: Automatically set by AI Studio at runtime.
# VITE_APP_URL=""
